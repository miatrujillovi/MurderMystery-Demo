  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cb143d27eaafdfd49b357914501eab37, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PuzzleManager
  clueDialogues:
    _serializedList:
    - Key: 0
      Value:
      - The door is locked.
      - I need to get inside.
    - Key: 1
      Value:
      - I left the keys under the flowerpot - Martha.
    - Key: 2
      Value:
      - A flowerpot.
      - There's nothing under it.
    - Key: 3
      Value:
      - Something is missing here...
    - Key: 4
      Value:
      - Is completly trapped by those veins.
      - Maybe I can use something to cut them.
    - Key: 5
      Value:
      - Got it.
    - Key: 6
      Value:
      - Why is there a flower wallpaper here?
    - Key: 7
      Value:
      - Lily = 0
    - Key: 8
      Value:
      - Sunflower = 3
    - Key: 9
      Value:
      - Rose = 8
    - Key: 10
      Value:
      - Tulip = 6
  solvedDialogues:
    _serializedList:
    - Key: 0
      Value:
      - '*Click*'
      - Lets go inside.
    - Key: 4
      Value:
      - '*Brum* *Brum*'
      - Is that flowerpot...
      - Let's take it to its original place.
    - Key: 3
      Value:
      - '*Cronch* *Click*'
      - Oh
      - There's a key under it.
      - I'll take it.
    - Key: 5
      Value:
      - '*Click* *Click*'
      - Finally open.
      - Maybe I can use it to cut something.
  dialogueManager: {fileID: 781055538}
  actionManager: {fileID: 528509915}
